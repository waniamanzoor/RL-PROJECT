{
  "manifest_version": 3,
  "name": "RL Task Tracker",
  "version": "1.0",
  "description": "Automatic time tracking for RL Task Scheduler",
  "permissions": ["tabs", "storage", "alarms", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://localhost:5173/*",
    "https://rl-project-api.onrender.com/*"
  ]
}
