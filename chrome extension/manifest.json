{
  "manifest_version": 3,
  "name": "RL Task Tracker",
  "version": "1.0",
  "description": "Automatic time tracking for RL Task Scheduler",
  "permissions": ["tabs", "storage", "alarms", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
"host_permissions": [
  "http://localhost:8000/*",
  "https://rl-project-api.onrender.com/*"
]
}
